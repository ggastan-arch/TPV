# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.ruff_cache/
build/
dist/

# Base de datos local: NUNCA versionar (contiene la cadena de registros fiscales
# y datos personales de clientes -> RGPD + secreto tributario).
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# tpv_demo.db (perfil demo, ADR-0009) ya queda cubierta por el patron *.db de
# arriba; entrada explicita para documentar la intencion: NUNCA versionar la BD
# demo, aunque sus datos sean ficticios (es un fichero desechable/portatil).
tpv_demo.db*

# Entorno / configuracion local con posibles secretos.
.env
.env.*
!.env.example

# Certificados y claves: el certificado de la persona titular NUNCA sale del servidor
# (invariante 7). Prohibido versionarlos en ningun caso.
*.pfx
*.p12
*.pem
*.cer
*.crt
*.key
*.jks
*.keystore
*.der

# Copias de seguridad
*.bak
backups/

# Imagenes de catalogo (articulo/familia): archivos servidos desde /media,
# desechables y regenerables via subida; NUNCA versionados (la BD solo guarda
# la ruta, ver app/infraestructura/imagenes.py).
media/

# Los XSD/WSDL oficiales de la AEAT (schemas/) SI se versionan: son publicos y los
# tests los necesitan. Un certificado alli quedaria cubierto por los patrones de arriba.

# Estado local de herramientas de agentes (no es codigo del proyecto)
.atl/
.claude/

# SO / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
.obsidian/
